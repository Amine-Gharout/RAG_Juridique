# Groq configuration
GROQ_API_KEY=your_groq_api_key_here
LEGAL_RAG_GROQ_MODEL=llama-3.3-70b-versatile
LEGAL_RAG_TEMPERATURE=0.2

# VoyageAI + FAISS vector retrieval configuration
VOYAGE_API_KEY=
LEGAL_RAG_EMBEDDING_PROVIDER=voyageai
LEGAL_RAG_EMBEDDING_MODEL=voyage-4-large
LEGAL_RAG_EMBEDDING_DIM=1024
LEGAL_RAG_USE_VECTOR_SEARCH=true
LEGAL_RAG_AUTO_BUILD_INDEX=false
# LEGAL_RAG_INDEX_DIR=out/embeddings/voyage-4-large-d1024
# LEGAL_RAG_FAISS_METRIC=ip
# LEGAL_RAG_EMBED_BATCH_SIZE=64

# Optional overrides for data files
# LEGAL_RAG_TIER_A=out/cleaning/16-FR-only.articles.trusted_A.jsonl
# LEGAL_RAG_TIER_B=out/cleaning/16-FR-only.articles.review_B.jsonl
# LEGAL_RAG_TIER_C=out/cleaning/16-FR-only.articles.quarantine_C.jsonl
